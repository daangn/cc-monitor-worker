{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cc-monitor",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-23",
  "compatibility_flags": [
    "enable_request_signal",
  ],
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "cc-monitor.krrt.io",
      "zone_name": "krrt.io",
      "custom_domain": true
    }
  ],
  "placement": {
    "region": "aws:us-west-1"
  },
  "observability": {
    "enabled": true,
  },
  "analytics_engine_datasets": [
    {
      "binding": "OTEL_METRICS",
      "dataset": "claude_code_metrics_v20250717"
    },
    {
      "binding": "PROXY_METRICS",
      "dataset": "claude_proxy_metrics_v20260316",
    },
  ],
  "upload_source_maps": true,
}
